SERVER_PORT=8083

SPRING_DATASOURCE_URL=jdbc:h2:file:./data/resume-builder-db;MODE=MySQL;DB_CLOSE_DELAY=-1
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.h2.Driver
SPRING_JPA_DIALECT=org.hibernate.dialect.H2Dialect
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

JWT_SECRET=replace_with_base64_encoded_secret
JWT_EXPIRATION=86400000

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:3000
SPRING_SECURITY_LOG_LEVEL=DEBUG
APP_LOG_LEVEL=DEBUG

HUGGINGFACE_API_KEY=replace_with_huggingface_key
HUGGINGFACE_API_URL=https://router.huggingface.co/v1
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct